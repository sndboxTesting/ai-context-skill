#!/usr/bin/env python3
"""
adwi-version — show current git commit, date, and branch.
Safe for Telegram / Safe Command API. Read-only git log call.
"""
import subprocess
import sys
from pathlib import Path

WORKSPACE = Path.home() / "SuneelWorkSpace"


def main() -> int:
    def git(*args: str) -> str:
        try:
            r = subprocess.run(
                ["git", "-C", str(WORKSPACE), *args],
                capture_output=True, text=True, timeout=10,
            )
            return r.stdout.strip() if r.returncode == 0 else ""
        except Exception:
            return ""

    commit  = git("rev-parse", "--short", "HEAD")
    date    = git("log", "-1", "--format=%ci")
    branch  = git("rev-parse", "--abbrev-ref", "HEAD")
    subject = git("log", "-1", "--format=%s")

    lines = [
        "Adwi Version",
        f"  Commit:  {commit or '?'}",
        f"  Date:    {date[:19] if date else '?'}",
        f"  Branch:  {branch or '?'}",
        f"  Summary: {subject[:60] if subject else '?'}",
    ]
    print("\n".join(lines))
    return 0


if __name__ == "__main__":
    sys.exit(main())
