#!/bin/zsh
# Loads the Safe Command API LaunchAgent and waits for port 5055 to respond.
# Use stop-command-api to stop it (launchd KeepAlive will NOT restart after bootout).
PLIST="$HOME/Library/LaunchAgents/com.suneel.command-api.plist"
LABEL="com.suneel.command-api"
DOMAIN="gui/$(id -u)"

if [[ ! -f "$PLIST" ]]; then
  echo "ERROR: plist not found: $PLIST" >&2
  exit 1
fi

if launchctl list "$LABEL" >/dev/null 2>&1; then
  echo "Safe Command API is already loaded ($LABEL)."
  curl -s --max-time 3 http://127.0.0.1:5055/ >/dev/null 2>&1 \
    && echo "Port 5055: responding." \
    || echo "Port 5055: not yet responding."
  exit 0
fi

launchctl bootstrap "$DOMAIN" "$PLIST"
echo "Safe Command API LaunchAgent loaded."
printf "Waiting for port 5055"
for i in $(seq 1 10); do
  sleep 1
  if curl -s --max-time 2 http://127.0.0.1:5055/ >/dev/null 2>&1; then
    echo " — up."
    exit 0
  fi
  printf "."
done
echo ""
echo "Port 5055 not responding after 10s — check /tmp/adwi-command-api.err"
exit 1
