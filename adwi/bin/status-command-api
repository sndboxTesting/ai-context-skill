#!/bin/zsh
LABEL="com.suneel.command-api"

echo "=== LAUNCHAGENT STATUS ==="
if launchctl list "$LABEL" >/dev/null 2>&1; then
  launchctl list "$LABEL"
else
  echo "LaunchAgent not loaded."
fi

echo ""
echo "=== PORT 5055 ==="
if lsof -tiTCP:5055 -sTCP:LISTEN >/dev/null 2>&1; then
  lsof -i :5055 -sTCP:LISTEN -nP 2>/dev/null | grep -v "^COMMAND"
else
  echo "Port 5055: no listener."
fi

echo ""
echo "=== API HEALTH CHECK ==="
curl -s --max-time 3 http://127.0.0.1:5055/ | python3 -m json.tool 2>/dev/null \
  || echo "API not responding."
