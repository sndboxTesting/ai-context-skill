#!/bin/zsh
# Unloads the Safe Command API LaunchAgent so it stays stopped.
# launchd KeepAlive will NOT restart the process after bootout.
PLIST="$HOME/Library/LaunchAgents/com.suneel.command-api.plist"
LABEL="com.suneel.command-api"
DOMAIN="gui/$(id -u)"

if [[ ! -f "$PLIST" ]]; then
  echo "ERROR: plist not found: $PLIST" >&2
  exit 1
fi

if ! launchctl list "$LABEL" >/dev/null 2>&1; then
  echo "Safe Command API is not loaded — nothing to stop."
  exit 0
fi

launchctl bootout "$DOMAIN" "$PLIST"
printf "Waiting for port 5055 to close"
for i in $(seq 1 10); do
  sleep 1
  if ! lsof -tiTCP:5055 -sTCP:LISTEN >/dev/null 2>&1; then
    echo " — closed."
    echo "Safe Command API stopped."
    exit 0
  fi
  printf "."
done
echo ""
echo "Port 5055 still open after 10s — check /tmp/adwi-command-api.err"
exit 1
