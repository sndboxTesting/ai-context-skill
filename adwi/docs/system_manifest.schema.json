{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://adwi.local/system_manifest.schema.json",
  "title": "Adwi System Manifest",
  "description": "Machine-readable ground truth for the Adwi local AI operating system. Generated by bin/generate-manifest. Consumed by documentation generators and validation scripts.",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "generated_by",
    "system_identity",
    "hardware_runtime",
    "models",
    "services",
    "launch_agents",
    "nlu_pipeline",
    "security",
    "command_registry",
    "eval_status",
    "phase_status",
    "documentation"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Semver of this manifest schema.",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "example": "1.0.0"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when this manifest was generated."
    },
    "generated_by": {
      "type": "string",
      "description": "Path to the generator script relative to workspace root.",
      "example": "bin/generate-manifest"
    },
    "system_identity": {
      "type": "object",
      "required": ["name", "operator", "repo_root", "entry_point", "description"],
      "properties": {
        "name":        { "type": "string", "example": "Adwi" },
        "operator":    { "type": "string", "example": "Suneel Bikkasani" },
        "repo_root":   { "type": "string", "example": "~/SuneelWorkSpace" },
        "entry_point": { "type": "string", "example": "bin/adwi → python3 adwi/adwi_cli.py" },
        "description": { "type": "string" }
      }
    },
    "hardware_runtime": {
      "type": "object",
      "required": ["cpu", "ram_gb", "os", "python_version", "package_manager"],
      "properties": {
        "cpu":             { "type": "string", "example": "Apple M4 Max (16-core)" },
        "ram_gb":          { "type": "integer", "example": 64 },
        "os":              { "type": "string", "example": "macOS 15 (Darwin 25.x)" },
        "python_version":  { "type": "string", "example": "3.14.5" },
        "venv_path":       { "type": "string", "example": "adwi/.venv" },
        "package_manager": { "type": "string", "example": "uv + pip" }
      }
    },
    "models": {
      "type": "object",
      "description": "All Ollama models used by Adwi. Keys are MODEL_* constants from adwi_cli.py.",
      "additionalProperties": {
        "type": "object",
        "required": ["model_id", "role"],
        "properties": {
          "model_id":       { "type": "string" },
          "role":           { "type": "string" },
          "context_tokens": { "type": "integer" },
          "size_gb":        { "type": "number" },
          "when_used":      { "type": "string" }
        }
      }
    },
    "services": {
      "type": "array",
      "description": "All network services (Docker, native, LaunchAgent). Authoritative port registry.",
      "items": {
        "type": "object",
        "required": ["name", "port", "layer", "purpose"],
        "properties": {
          "name":      { "type": "string" },
          "port":      { "type": "integer" },
          "layer":     { "type": "string", "enum": ["docker-compose", "docker-launchagent", "host-native", "host-launchagent"] },
          "purpose":   { "type": "string" },
          "managed_by": { "type": "string", "description": "docker-compose service name, plist label, or binary" }
        }
      }
    },
    "launch_agents": {
      "type": "array",
      "description": "macOS LaunchAgents under ~/Library/LaunchAgents/com.suneel.*.plist.",
      "items": {
        "type": "object",
        "required": ["label", "schedule"],
        "properties": {
          "label":    { "type": "string" },
          "plist":    { "type": "string" },
          "schedule": { "type": "string" },
          "purpose":  { "type": "string" }
        }
      }
    },
    "nlu_pipeline": {
      "type": "object",
      "required": ["intent_count", "fixture_count", "regex_intent_count", "fast_path_threshold"],
      "properties": {
        "intent_count":        { "type": "integer", "description": "Count of entries in _ALL_INTENTS in adwi_cli.py." },
        "fixture_count":       { "type": "integer", "description": "Live count in Qdrant nlu_fixtures collection." },
        "regex_intent_count":  { "type": "integer", "description": "Count of regex patterns in _REGEX_INTENTS." },
        "fast_path_threshold": { "type": "number",  "description": "Qdrant score threshold that bypasses llama3.1:8b.", "example": 0.88 },
        "nlu_model":           { "type": "string",  "example": "llama3.1:8b" },
        "fallback_model":      { "type": "string",  "example": "qwen3:0.6b" },
        "qdrant_collection":   { "type": "string",  "example": "nlu_fixtures" }
      }
    },
    "security": {
      "type": "object",
      "required": ["blocked_roots", "gitignore_sensitive_patterns", "invariants"],
      "properties": {
        "blocked_roots": {
          "type": "array",
          "description": "Paths that PathValidator always denies. Sourced from adwi/path_validator.py.",
          "items": { "type": "string" }
        },
        "gitignore_sensitive_patterns": {
          "type": "array",
          "description": "Patterns that must never be committed. Sourced from .gitignore.",
          "items": { "type": "string" }
        },
        "invariants": {
          "type": "array",
          "description": "Hard security rules that must never be weakened.",
          "items": { "type": "string" }
        }
      }
    },
    "command_registry": {
      "type": "object",
      "required": ["total_commands", "source_files", "last_counted"],
      "properties": {
        "total_commands": {
          "type": "integer",
          "description": "Authoritative command count extracted by bin/auto-update-readme extract_commands()."
        },
        "source_files": {
          "type": "array",
          "description": "Files that contribute commands to the registry.",
          "items": { "type": "string" }
        },
        "last_counted": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "eval_status": {
      "type": "object",
      "required": ["p1_pass_rate", "p2_pass_rate", "combined_pass_rate", "stop_condition_met", "measured_at"],
      "properties": {
        "p1_pass_rate":          { "type": "number", "minimum": 0, "maximum": 1 },
        "p2_pass_rate":          { "type": "number", "minimum": 0, "maximum": 1 },
        "combined_pass_rate":    { "type": "number", "minimum": 0, "maximum": 1 },
        "stop_condition_met":    { "type": "boolean", "description": "True when combined >= 95%." },
        "stop_condition_threshold": { "type": "number", "example": 0.95 },
        "p1_scenarios":          { "type": "integer" },
        "p2_scenarios":          { "type": "integer" },
        "measured_at":           { "type": "string", "format": "date" },
        "report_path":           { "type": "string" }
      }
    },
    "phase_status": {
      "type": "array",
      "description": "Implementation phase registry. Each phase is an atomic engineering mandate.",
      "items": {
        "type": "object",
        "required": ["phase", "title", "status"],
        "properties": {
          "phase":       { "type": "integer" },
          "title":       { "type": "string" },
          "status":      { "type": "string", "enum": ["complete", "in_progress", "planned"] },
          "key_files":   { "type": "array", "items": { "type": "string" } },
          "description": { "type": "string" }
        }
      }
    },
    "documentation": {
      "type": "object",
      "description": "Provenance and ownership of each documentation artifact.",
      "properties": {
        "readme": {
          "type": "object",
          "properties": {
            "path":        { "type": "string" },
            "auto_sections": { "type": "array", "items": { "type": "string" } },
            "static_sections": { "type": "array", "items": { "type": "string" } },
            "generator":   { "type": "string" }
          }
        },
        "canonical_files": {
          "type": "array",
          "description": "Files that are ground truth (code > docs).",
          "items": { "type": "string" }
        },
        "generated_files": {
          "type": "array",
          "description": "Files partially or fully produced by generators.",
          "items": { "type": "string" }
        },
        "historical_files": {
          "type": "array",
          "description": "Files with archival content; not kept current.",
          "items": { "type": "string" }
        }
      }
    }
  }
}
