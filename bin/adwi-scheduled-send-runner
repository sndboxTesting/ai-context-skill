#!/usr/bin/env python3
"""
adwi-scheduled-send-runner — Phase 10 scheduled-send executor.

Reads adwi/scheduled_sends.json, sends any pending entries whose
send_at_iso has passed, updates their status in-place.

Run by LaunchAgent com.suneel.adwi-scheduled-send every 2 minutes.
Standalone: does NOT import adwi_cli.py.
"""
import json
import sys
from datetime import datetime
from pathlib import Path

BASE              = Path(__file__).resolve().parents[1]
QUEUE_FILE        = BASE / "adwi" / "scheduled_sends.json"
GMAIL_HELPER      = BASE / "adwi" / "gmail_helper.py"
LOG_FILE          = Path("/tmp/adwi-scheduled-send.log")

sys.path.insert(0, str(BASE / "adwi"))


def _log(msg: str) -> None:
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    line = f"[{ts}] {msg}"
    print(line, flush=True)
    try:
        with LOG_FILE.open("a") as f:
            f.write(line + "\n")
    except OSError:
        pass


def _load() -> list:
    try:
        return json.loads(QUEUE_FILE.read_text(encoding="utf-8"))
    except (FileNotFoundError, json.JSONDecodeError):
        return []


def _save(entries: list) -> None:
    tmp = QUEUE_FILE.with_suffix(".json.tmp")
    tmp.write_text(json.dumps(entries, indent=2, default=str), encoding="utf-8")
    tmp.replace(QUEUE_FILE)


def main() -> None:
    if not QUEUE_FILE.exists():
        sys.exit(0)

    entries = _load()
    now     = datetime.now()
    changed = False

    for entry in entries:
        if entry.get("status") != "pending":
            continue
        try:
            send_at = datetime.fromisoformat(entry["send_at_iso"])
        except (KeyError, ValueError) as e:
            _log(f"SKIP bad send_at_iso on {entry.get('id','?')}: {e}")
            continue

        if send_at > now:
            continue  # not yet due

        draft_id = entry.get("draft_id", "")
        subject  = entry.get("subject", "?")
        _log(f"SENDING scheduled entry {entry.get('id','?')}  subject='{subject[:50]}'  draft={draft_id[:20]}")

        try:
            import gmail_helper as gh
            result = gh.send_draft(draft_id)
            entry["status"]    = "sent"
            entry["sent_at"]   = datetime.now().isoformat(timespec="seconds")
            entry["result_id"] = result.get("id", "")[:30]
            _log(f"  SENT ok — msg_id={entry['result_id']}")
        except Exception as e:
            entry["status"]      = "failed"
            entry["failed_at"]   = datetime.now().isoformat(timespec="seconds")
            entry["error"]       = str(e)[:200]
            _log(f"  FAILED: {e}")

        changed = True

    if changed:
        _save(entries)


if __name__ == "__main__":
    main()
