      "id": "FIX-001",
      "title": "file_search regex too broad \u2014 swallows cleanup/duplicates/large_files",
      "count": 27,
      "evidence": [
        "find my heaviest files",
        "find fat files",
        "find files exceeding 1 gigabyte",
        "find oversized files",
